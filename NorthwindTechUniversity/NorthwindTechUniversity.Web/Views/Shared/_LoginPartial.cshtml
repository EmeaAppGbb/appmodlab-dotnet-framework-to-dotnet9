@if (User.Identity?.IsAuthenticated == true)
{
    <ul class="nav navbar-nav navbar-right">
        <li>
            <a asp-controller="Manage" asp-action="Index" title="Manage">Hello @User.Identity.Name!</a>
        </li>
        <li>
            <form asp-controller="Account" asp-action="LogOff" method="post" id="logoutForm" class="navbar-right">
                <button type="submit" class="btn btn-link navbar-btn navbar-link">Log off</button>
            </form>
        </li>
    </ul>
}
else
{
    <ul class="nav navbar-nav navbar-right">
        <li><a asp-controller="Account" asp-action="Register" id="registerLink">Register</a></li>
        <li><a asp-controller="Account" asp-action="Login" id="loginLink">Log in</a></li>
    </ul>
}
